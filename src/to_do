#example
cmake_minimum_required(VERSION 3.8)
project(example)

if(CMAKE_COMPILER_IS_GNUCXX OR CMAKE_CXX_COMPILER_ID MATCHES "Clang")
  add_compile_options(-Wall -Wextra -Wpedantic)
endif()

# Find dependencies
find_package(ament_cmake REQUIRED)
find_package(rclcpp REQUIRED)
find_package(rclcpp_lifecycle REQUIRED)
find_package(hardware_interface REQUIRED)
find_package(controller_manager REQUIRED)
find_package(pluginlib REQUIRED)
find_package(gazebo_ros2_control REQUIRED)
find_package(ros2_control REQUIRED)
find_package(serial REQUIRED)
find_package(OpenCV REQUIRED)
find_package(fixed_size_msgs REQUIRED)
find_package(iceoryx_posh REQUIRED)
find_package(iceoryx_hoofs REQUIRED)
find_package(realsense2 REQUIRED)

# Include directories
include_directories(
  include
  ${OpenCV_INCLUDE_DIRS}
)

# ----------------------------
# Camera nodes
# ----------------------------
add_executable(camera1_pub src/camera1_pub.cpp)
ament_target_dependencies(camera1_pub
  rclcpp OpenCV fixed_size_msgs realsense2
)
target_link_libraries(camera1_pub iceoryx_hoofs::iceoryx_hoofs iceoryx_posh::iceoryx_posh ${realsense2_LIBRARY})

add_executable(camera1_sub src/camera1_sub.cpp)
ament_target_dependencies(camera1_sub rclcpp OpenCV fixed_size_msgs)
target_link_libraries(camera1_sub iceoryx_hoofs::iceoryx_hoofs iceoryx_posh::iceoryx_posh)

add_executable(camera2_pub src/camera2_pub.cpp)
ament_target_dependencies(camera2_pub rclcpp OpenCV fixed_size_msgs realsense2)
target_link_libraries(camera2_pub iceoryx_hoofs::iceoryx_hoofs iceoryx_posh::iceoryx_posh ${realsense2_LIBRARY})

add_executable(camera2_sub src/camera2_sub.cpp)
ament_target_dependencies(camera2_sub rclcpp OpenCV fixed_size_msgs)
target_link_libraries(camera2_sub iceoryx_hoofs::iceoryx_hoofs iceoryx_posh::iceoryx_posh)

# ----------------------------
# GPS hardware plugin (for simulation)
# ----------------------------
add_library(example_gps SHARED hardware/example.cpp)
target_include_directories(example_gps PUBLIC
  $<BUILD_INTERFACE:${PROJECT_SOURCE_DIR}/hardware/include>
  $<INSTALL_INTERFACE:include/example>
)
ament_target_dependencies(example_gps
  rclcpp rclcpp_lifecycle hardware_interface controller_manager pluginlib serial
)
pluginlib_export_plugin_description_file(hardware_interface example_gps.xml)

# ----------------------------
# Install targets
# ----------------------------
install(TARGETS
  camera1_pub camera1_sub camera2_pub camera2_sub
  RUNTIME DESTINATION lib/${PROJECT_NAME}
)

install(DIRECTORY rviz
  DESTINATION share/${PROJECT_NAME}/rviz
)

install(DIRECTORY hardware/include/
  DESTINATION include/example
)

install(DIRECTORY description/urdf description/ros2_control_description
  DESTINATION share/example
)

install(DIRECTORY bringup/config
  DESTINATION share/example
)

install(TARGETS example_gps
  EXPORT export_example
  ARCHIVE DESTINATION lib
  LIBRARY DESTINATION lib
  RUNTIME DESTINATION bin
)

# ----------------------------
# Testing / linting
# ----------------------------
if(BUILD_TESTING)
  find_package(ament_lint_auto REQUIRED)
  set(ament_cmake_copyright_FOUND TRUE)
  set(ament_cmake_cpplint_FOUND TRUE)
  ament_lint_auto_find_test_dependencies()
endif()

ament_package()
